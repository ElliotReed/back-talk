---
import { Icon } from "astro-icon/components";
---

<header>
    <a href="/display/home" class="logo">
        <h1>Example Company</h1>
        <p>A simple platform for modern teams and individuals.</p>
    </a>

    <nav>
        <ul>
            <li><a href="/display/colors">Colors</a></li>
            <li><a href="#">Solutions</a></li>
            <li><a href="#">Pricing</a></li>
            <li><a href="#">Contact</a></li>
        </ul>
        <a href="/reference">Reference</a>
    </nav>
    <div class="theme-selector">
        <span class="theme-icon" data-icon="auto"
            ><Icon name="lucide:computer" /></span
        >
        <span class="theme-icon" data-icon="light"
            ><Icon name="lucide:sun" /></span
        >
        <span class="theme-icon" data-icon="dark"
            ><Icon name="lucide:moon" /></span
        >
        <select id="theme-selector">
            <option value="auto">Auto</option>
            <option value="light">Light</option>
            <option value="dark">Dark</option>
        </select>
    </div>
</header>

<script>
    type Theme = "auto" | "dark" | "light";

    const html = document.documentElement;
    const media = window.matchMedia("(prefers-color-scheme: dark)");
    const select = document.getElementById(
        "theme-selector",
    )! as HTMLSelectElement;

    function updateIcon(theme: Theme) {
        document.querySelectorAll(".theme-icon").forEach((icon) => {
            const el = icon as HTMLElement;
            el.style.display = el.dataset.icon === theme ? "inline" : "none";
        });
    }

    function getStoredTheme() {
        return localStorage.getItem("theme") as Theme | null;
    }

    function storeTheme(theme: Theme) {
        localStorage.setItem("theme", theme);
    }

    function clearStoredTheme() {
        localStorage.removeItem("theme");
    }

    function getInitialTheme(): Theme {
        return getStoredTheme() ?? "auto";
    }

    function applyTheme(theme: Theme) {
        if (theme === "auto") {
            html.setAttribute("data-theme", media.matches ? "dark" : "light");
        } else {
            html.setAttribute("data-theme", theme);
        }
        updateIcon(theme);
    }

    function init() {
        const theme = getInitialTheme();
        applyTheme(theme);
        select.value = theme;
    }

    init();

    document.addEventListener("astro:after-swap", init);

    media.addEventListener("change", (e) => {
        if (!getStoredTheme()) {
            html.setAttribute("data-theme", e.matches ? "dark" : "light");
        }
    });

    select.addEventListener("change", function () {
        const value = this.value as Theme;
        if (value === "auto") {
            clearStoredTheme();
        } else {
            storeTheme(value);
        }
        applyTheme(value);
    });
</script>

<style lang="scss">
    @use "mixins" as *;

    header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: var(--color-header-background);
        color: var(--color-header-text);

        .logo {
            font-family: var(--font-heading);
            font-size: smaller;
            text-decoration: none;

            > :not(p) {
                color: var(--color-primary-500);
            }
        }

        @include padding-box("sm");
        nav {
            display: flex;
            align-items: center;
            ul {
                display: flex;
                list-style: none;

                a {
                    @include padding-box("sm");
                    text-decoration: none;
                }
            }
        }
    }

    #theme-selector {
        width: 1rem;
    }
</style>
