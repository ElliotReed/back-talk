---
import DisplayLayout from "../../layouts/DisplayLayout.astro";
---

<DisplayLayout title="Home" description="A sample landing page">
    <main>
        <section>
            <h2>Build Better Workflows</h2>

            <p class="hero">
                Our platform helps individuals and teams organize tasks,
                collaborate, and keep projects moving forward. The focus is on
                clarity, flexibility, and ease of use.
            </p>

            <p>
                Whether you're managing a personal project or coordinating a
                team, everything stays organized in one place.
            </p>

            <button>Get Started</button>
            <button>Learn More</button>
        </section>

        <section>
            <h2>Core Features</h2>

            <article>
                <h3>Flexible Organization</h3>
                <p>
                    Structure your work the way you prefer. Create groups,
                    categories, and collections that reflect your workflow.
                </p>
            </article>

            <article>
                <h3>Collaboration Tools</h3>
                <p>
                    Invite others, share updates, and keep discussions connected
                    to the work that matters.
                </p>
            </article>

            <article>
                <h3>File and Resource Management</h3>
                <p>
                    Store documents, notes, and resources alongside the projects
                    they belong to.
                </p>
            </article>
        </section>

        <section>
            <h2>How It Works</h2>

            <ol>
                <li>Create a workspace.</li>
                <li>Add projects and tasks.</li>
                <li>Invite collaborators.</li>
                <li>Track progress and updates.</li>
            </ol>

            <p>
                Visit the <a href="#">documentation</a> or explore the
                <a href="#">guides</a> to get started.
            </p>
        </section>

        <section>
            <h2>Plan Comparison</h2>

            <table>
                <thead>
                    <tr>
                        <th>Feature</th>
                        <th>Basic</th>
                        <th>Advanced</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Projects</td>
                        <td>10</td>
                        <td>Unlimited</td>
                    </tr>
                    <tr>
                        <td>Team Members</td>
                        <td>5</td>
                        <td>Unlimited</td>
                    </tr>
                    <tr>
                        <td>Storage</td>
                        <td>5GB</td>
                        <td>100GB</td>
                    </tr>
                </tbody>
            </table>
        </section>

        <section>
            <h2>What People Say</h2>

            <blockquote>
                “This tool made it easier to keep track of everything in one
                place.”
            </blockquote>
            <cite>— Product Manager</cite>

            <blockquote>
                “Clean, simple, and flexible enough for our workflow.”
            </blockquote>
            <cite>— Team Lead</cite>
        </section>

        <section>
            <h2>Quick Signup</h2>

            <form>
                <fieldset>
                    <legend>Create an account</legend>

                    <label for="name">Name</label>
                    <input id="name" type="text" placeholder="Jane Doe" />

                    <label for="email">Email</label>
                    <input
                        id="email"
                        type="email"
                        placeholder="jane@example.com"
                    />

                    <label for="role">Role</label>
                    <select id="role">
                        <option>Developer</option>
                        <option>Designer</option>
                        <option>Manager</option>
                        <option>Other</option>
                    </select>

                    <label>
                        <input type="checkbox" /> Subscribe to updates
                    </label>

                    <button type="submit">Create Account</button>
                </fieldset>
            </form>
        </section>

        <section>
            <h2>Resources</h2>

            <ul class="shadowed">
                <li><a href="#">Documentation</a></li>
                <li><a href="#">Tutorials</a></li>
                <li><a href="#">Community</a></li>
                <li><a href="#">Support</a></li>
            </ul>

            <details>
                <summary>Frequently Asked Question</summary>
                <p>
                    The service works in modern browsers and supports both
                    desktop and mobile devices.
                </p>
            </details>
        </section>
    </main>

    <footer>
        <p>&copy; 2026 Example Company</p>

        <address>
            Contact: <a href="mailto:info@example.com">info@example.com</a>
        </address>

        <small> Terms of service and privacy policy apply. </small>
    </footer>
</DisplayLayout>

<style lang="scss">
    @use "mixins" as *;
    main {
        margin-inline: var(--space-gutter);
    }

    .hero {
        @include box-input;
        @include shadow(1);
    }

    button {
        background-color: var(--color-accent);
        @include padding-box;
    }
    .shadowed {
        @include shadow(3);
    }
</style>
