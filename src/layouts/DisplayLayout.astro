---
import SiteHeader from "../components/demoPages/SiteHeader.astro";

const { title, description, headerMode } = Astro.props;
---

<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <title>{title}</title>

        <!-- description for if these pages ever get indexed -->
        <meta name="description" content={description} />

        <!-- prevent indexing — these are dev/demo pages not public content -->
        <meta name="robots" content="noindex, nofollow" />

        <!-- colour scheme — tells browser before CSS loads, prevents flash -->
        <meta name="color-scheme" content="light dark" />

        <!-- fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <SiteHeader mode={headerMode} />
        <slot />
        <footer>backtalk demo page</footer>
    </body>

    <style lang="scss" is:global>
        @use "index.scss";
    </style>
</html>
